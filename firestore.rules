// Rushtown Poultry — Firestore Security Rules (open access)
//
// Login was removed because too many farm staff don't have email
// accounts. These rules match the pre-auth behavior: anyone with the
// URL can read and write the database. Deploy with:
//   firebase deploy --only firestore:rules
//
// When you're ready to add auth back, replace the rule body with:
//   allow read, write: if request.auth != null;
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
